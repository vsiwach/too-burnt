# Database — SQLite for local dev; swap to Postgres (Supabase) for production
DATABASE_URL="file:./dev.db"

# Email delivery (Resend — https://resend.com, free tier 3k/mo)
# RESEND_API_KEY="re_..."
# RESEND_FROM="Too Burnt <reservations@yourdomain.com>"  # or default: "Too Burnt <onboarding@resend.dev>" while testing
# RESTAURANT_EMAIL="hello@tooburnt.com"                   # where reservation notifications go

# Telegram bot notifications (free) — set up via @BotFather, then send /start to your bot
# TELEGRAM_BOT_TOKEN="1234567890:ABC..."
# TELEGRAM_CHAT_ID="123456789"

# Admin dashboard — append ?token=<ADMIN_TOKEN> to /admin
# ADMIN_TOKEN="pick-a-long-random-string"

# Stripe (test mode to start — https://dashboard.stripe.com/test/apikeys)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# DEPOSIT_PER_SEAT_CENTS="1000"     # $10/seat deposit (set to 0 to disable)
# PUBLIC_BASE_URL="http://localhost:3100"
