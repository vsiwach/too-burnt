# Database — Postgres (Neon/Supabase). For local dev you can still use SQLite by changing
# the schema.prisma provider back to "sqlite" and DATABASE_URL to "file:./dev.db".
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Admin login (login protects /admin/* and /api/invites)
ADMIN_PASSWORD="pick-a-strong-password"
SESSION_SECRET="random-48-byte-base64url-string"   # node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"

# Email delivery (Resend — https://resend.com, free tier 3k/mo)
# RESEND_API_KEY="re_..."
# RESEND_FROM="Too Burnt <reservations@yourdomain.com>"  # default: "Too Burnt <onboarding@resend.dev>" while testing
# RESTAURANT_EMAIL="hello@tooburnt.com"                   # where reservation notifications go

# Telegram bot notifications (free) — set up via @BotFather, then send /start to your bot
# TELEGRAM_BOT_TOKEN="1234567890:ABC..."
# TELEGRAM_CHAT_ID="123456789"

# Stripe (future — card payments)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
